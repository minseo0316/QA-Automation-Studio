<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <AssemblyName>QA-Automation-Studio</AssemblyName>
    <Product>QA Automation Studio</Product>
    <Title>QA Automation Studio</Title>
    <Description>Unity PlayMode test automation, evidence capture, and reporting studio.</Description>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="UnityTestKit\**\*.cs" />
    <None Include="UnityTestKit\**\*" />
  </ItemGroup>

</Project>
